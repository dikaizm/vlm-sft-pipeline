# ============================================================
# VLM SFT Pipeline — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# Dataset paths
# ------------------------------------------------------------
# Root directory containing UCFCrime_Train.json, UCFCrime_Val.json,
# UCFCrime_Test.json, and the UCF_Crimes/UCF_Crimes/Videos/ folder
DATA_ROOT=/path/to/data

# ------------------------------------------------------------
# Output
# ------------------------------------------------------------
# Where model checkpoints and logs are saved
OUTPUT_DIR=./output/smolvlm2-500m-small-sft

# ------------------------------------------------------------
# Model
# ------------------------------------------------------------
# HuggingFace model ID for the base model to fine-tune
MODEL_ID=HuggingFaceTB/SmolVLM2-500M-Video-Instruct

# ------------------------------------------------------------
# Fine-tuned model directory (used by infer.py and infer_dense.py)
# ------------------------------------------------------------
# For clip captioning (train_small.py output):
# FINETUNED_DIR=./output/smolvlm2-500m-small-sft
# For dense captioning (train_dense.py output):
# FINETUNED_DIR=./output/smolvlm2-500m-dense-sft
FINETUNED_DIR=./output/smolvlm2-500m-dense-sft

# ------------------------------------------------------------
# MLflow tracking
# ------------------------------------------------------------
MLFLOW_URI=https://mlflow-geoai.stelarea.com/
# Set per-task:
#   clip captioning : smolvlm2-surveillance-sft
#   dense captioning: smolvlm2-surveillance-dense
MLFLOW_EXPERIMENT=smolvlm2-surveillance-dense
