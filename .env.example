# ============================================================
# VLM SFT Pipeline — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# Dataset paths
# ------------------------------------------------------------
# Root directory containing UCFCrime_Train.json, UCFCrime_Val.json,
# UCFCrime_Test.json, and the UCF_Crimes/UCF_Crimes/Videos/ folder
DATA_ROOT=/path/to/data

# ------------------------------------------------------------
# Output
# ------------------------------------------------------------
# Where model checkpoints and logs are saved
OUTPUT_DIR=./output/smolvlm2-500m-small-sft

# ------------------------------------------------------------
# Model
# ------------------------------------------------------------
# HuggingFace model ID for the base model to fine-tune
MODEL_ID=HuggingFaceTB/SmolVLM2-500M-Video-Instruct

# ------------------------------------------------------------
# MLflow tracking
# ------------------------------------------------------------
MLFLOW_URI=https://mlflow-geoai.stelarea.com/
MLFLOW_EXPERIMENT=smolvlm2-surveillance-sft
